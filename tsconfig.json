{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types", "vitest/globals"]
  },
  "include": ["worker/**/*.ts", "tests/**/*.ts", "frontend/src/**/*.ts", "frontend/src/**/*.svelte", "frontend/vite.config.ts"]
}
